# Copy to `.env` and never commit `.env` (it is gitignored).
# Put all real API keys, Stripe, and Google client values only in `.env` — not in this file.

# Backend API URL (default if `make run` uses PORT=8080)
VITE_API_URL=http://localhost:8080/api

# Production (https://rloko.com) — same-origin API: path is /api (see .do/app.yaml)
# VITE_API_URL=https://rloko.com/api
# If port 8080 is already used (e.g. another Docker container), run backend with PORT=8081 and set:
# VITE_API_URL=http://localhost:8081/api

# Docker: `frontend/docker-compose.yml` sets VITE_API_URL=http://localhost:8080/api in `environment`
# so the dev container always uses your local Docker backend (8080), even if this file points to cloud.

# Stripe publishable key (test: pk_test_... from https://dashboard.stripe.com/apikeys)
# Required for card payments at checkout.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Google Sign-In (Login with Google) ────────────────────────────────────────
# Same value as GOOGLE_CLIENT_ID in backend/.env
# Get it: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Create "Web application" and add your origins (e.g. http://localhost:5173, https://rloco-frontend.pages.dev)
# No client secret needed for this flow.
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# ─── Address Autocomplete ──────────────────────────────────────────────────────
# Google Places API key — get it at https://console.cloud.google.com
#   1. Create a project → Enable "Places API" + "Maps JavaScript API"
#   2. APIs & Services → Credentials → Create API Key
#   3. Restrict key to your domain in production
#   Free tier: $200/month credit ≈ 40,000 autocomplete calls/month (usually enough)
# VITE_GOOGLE_MAPS_API_KEY=AIza...
